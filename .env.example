# Example .env for Drishti backend
# Copy this file to .env and fill values (do NOT commit .env)

# Provider: 'smtp' or 'sendgrid'
DRISHTI_MAIL_PROVIDER=smtp

# SMTP (Gmail) example — use an App Password, not your main password
DRISHTI_SMTP_USER=your.email@gmail.com
DRISHTI_SMTP_PASS=your_app_password_here

# Optional: email-to-sms gateway domain for carrier SMS via SMTP
# e.g., tmomail.net, vtext.com, txt.att.net
DRISHTI_SMS_GATEWAY=tmomail.net

# SendGrid example (if using SendGrid)
#DRISHTI_MAIL_PROVIDER=sendgrid
#DRISHTI_SENDGRID_API_KEY=SG.xxxxx
#DRISHTI_SENDGRID_FROM=no-reply@yourdomain.com

# Twilio optional (if using Twilio for SMS)
#DRISHTI_TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxx
#DRISHTI_TWILIO_TOKEN=your_twilio_token
#DRISHTI_TWILIO_FROM=+1234567890
